# vaporRMM staging environment configuration
# Copy this file to .env.staging and fill in the required values.

# Required: JWT signing secret (min 32 chars recommended)
JWT_SECRET=change-me-in-production-use-a-random-32-char-string

# Optional: CORS origins (default allows localhost:3000)
CORS_ORIGINS=http://localhost:3000

# Optional: Admin password (auto-generated if not set)
# ADMIN_PASSWORD=StagingAdmin123!

# Optional: Device offline threshold in seconds
OFFLINE_THRESHOLD_SECONDS=120

# Optional: Metrics retention in seconds
METRICS_RETENTION_SECONDS=86400

# Optional: Grafana admin password
GRAFANA_PASSWORD=admin
