# vaporRMM Server & Testing Configuration
# Copy this file to .env and customize

# ============================================
# REQUIRED
# ============================================

# Strong random secret for JWT signing
# Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this

# Initial admin password
ADMIN_PASSWORD=YourStrongAdminPassword123!

# ============================================
# OPTIONAL: Tailscale Integration
# ============================================

# Get an auth key from https://login.tailscale.com/admin/settings/keys
# Set this to enable Tailscale features in the dashboard
# TAILSCALE_AUTH_KEY=tskey-auth-k1234567cnTRL-abcdefghijklmnopqrstuvwxyz

# ============================================
# OPTIONAL: Advanced Server Settings
# ============================================

# Database (SQLite default)
# DATABASE_PATH=/app/data/vapor_rmm.db

# For PostgreSQL, uncomment in docker-compose.full.yml and use:
# DATABASE_URL=postgres://vaporrmm:vaporrmm@postgres:5432/vaporrmm?sslmode=disable

# Server binding
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8080

# CORS origins (add your Tailscale MagicDNS domain if using Tailscale)
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://vaporrmm-server.your-tailnet.ts.net

# Agent settings
# DEFAULT_OFFLINE_THRESHOLD=300
# AGENT_REGISTRATION_SECRET=

# ============================================
# OPTIONAL: Moonlight Web Stream
# ============================================

# Set to the LAN IP of the Docker host for WebRTC NAT traversal
# WEBRTC_NAT_1TO1_HOST=192.168.1.100

# URL where the dashboard can reach moonlight-web-stream
# MOONLIGHT_WEB_URL=http://localhost:8081

# ============================================
# TLS (optional)
# ============================================
# TLS_CERT=/app/certs/server.crt
# TLS_KEY=/app/certs/server.key
# AGENT_CA_CERT=/app/certs/ca.crt

# ============================================
# Redis (optional)
# ============================================
# REDIS_ADDR=redis:6379
# REDIS_PASSWORD=
# REDIS_DB=0
