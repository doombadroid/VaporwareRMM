	// Device endpoints
	devices := api.Group("/devices")

	// Get all devices
	devices.Get("/", func(c *fiber.Ctx) error {
		rows, err := db.Query(
			`SELECT id, name, hostname, ip_address, mac_address, os_name, os_version, kernel_version, agent_version,
			 status, last_seen, created_at, public_key, user_data, system_uuid, serial_number, manufacturer, model,
			 cpu, memory, disk_size, timezone, agent_port, agent_ip FROM devices ORDER BY last_seen DESC`,
		)
		if err != nil {
			return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{
				"error": "Failed to query devices",
			})
		}
		defer rows.Close()

		var deviceList []serverDevice
		for rows.Next() {
			d, err := scanDevice(rows)
			if err != nil {
				log.Printf("Error scanning device: %v", err)
				continue
			}
			deviceList = append(deviceList, *d)
		}

		return c.JSON(deviceList)
	})

	// Get device by ID
	devices.Get("/:id", func(c *fiber.Ctx) error {
		id := c.Params("id")
		row := db.QueryRow(
			`SELECT id, name, hostname, ip_address, mac_address, os_name, os_version, kernel_version, agent_version,
			 status, last_seen, created_at, public_key, user_data, system_uuid, serial_number, manufacturer, model,
			 cpu, memory, disk_size, timezone, agent_port, agent_ip FROM devices WHERE id = ?`,
			id,
		)
		d, err := scanDevice(row)
		if err != nil {
			return c.Status(fiber.StatusNotFound).JSON(fiber.Map{
				"error": "Device not found",
			})
		}
		return c.JSON(d)
	})

	// Register new device (manual registration via API)
	devices.Post("/", func(c *fiber.Ctx) error {
		var device models.NewDeviceInput
		if err := c.BodyParser(&device); err != nil {
			return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{
				"error": "Invalid request body",
			})
		}

		deviceID := uuid.New().String()
		now := time.Now().Unix()

		_, err := db.Exec(
			`INSERT INTO devices (id, name, hostname, ip_address, mac_address, os_name, os_version, status, last_seen, created_at)
			 VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,
			deviceID, device.Name, device.Hostname, device.IPAddress, device.MacAddress,
			device.OSName, device.OSVersion, "offline", now, now,
		)
		if err != nil {
			return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{
				"error": "Failed to insert device",
			})
		}

		return c.Status(fiber.StatusCreated).JSON(serverDevice{
			ID:        deviceID,
			Name:      device.Name,
			Hostname:  device.Hostname,
			IPAddress: device.IPAddress,
			OSName:    device.OSName,
			OSVersion: device.OSVersion,
			Status:    "offline",
			CreatedAt: now,
			LastSeen:  now,
		})
	})

	// Update device
	devices.Put("/:id", func(c *fiber.Ctx) error {
		id := c.Params("id")

		var update models.UpdateDeviceInput
		if err := c.BodyParser(&update); err != nil {
			return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{
				"error": "Invalid request body",
			})
		}

		fields := []string{"last_seen = ?"}
		args := []interface{}{time.Now().Unix()}

		if update.Name != nil {
			fields = append(fields, "name = ?")
			args = append(args, *update.Name)
		}
		if update.Hostname != nil {
			fields = append(fields, "hostname = ?")
			args = append(args, *update.Hostname)
		}
		if update.Status != nil {
			fields = append(fields, "status = ?")
			args = append(args, *update.Status)
		}

		args = append(args, id)

		query := fmt.Sprintf("UPDATE devices SET %s WHERE id = ?", strings.Join(fields, ", "))
		result, err := db.Exec(query, args...)
		if err != nil {
			return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{
				"error": "Failed to update device",
			})
		}

		rowsAffected, _ := result.RowsAffected()
		if rowsAffected == 0 {
			return c.Status(fiber.StatusNotFound).JSON(fiber.Map{
				"error": "Device not found",
			})
		}

		row := db.QueryRow(
			`SELECT id, name, hostname, ip_address, mac_address, os_name, os_version, kernel_version, agent_version,
			 status, last_seen, created_at, public_key, user_data, system_uuid, serial_number, manufacturer, model,
			 cpu, memory, disk_size, timezone, agent_port, agent_ip FROM devices WHERE id = ?`,
			id,
		)
		d, err := scanDevice(row)
		if err != nil {
			return c.Status(fiber.StatusNotFound).JSON(fiber.Map{
				"error": "Device not found after update",
			})
		}

		return c.JSON(d)
	})

	// Delete device
	devices.Delete("/:id", func(c *fiber.Ctx) error {
		id := c.Params("id")

		result, err := db.Exec("DELETE FROM devices WHERE id = ?", id)
		if err != nil {
			return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{
				"error": "Failed to delete device",
			})
		}

		rowsAffected, _ := result.RowsAffected()
		if rowsAffected == 0 {
			return c.Status(fiber.StatusNotFound).JSON(fiber.Map{
				"error": "Device not found",
			})
		}

		// Remove agent token if exists
		tokenMu.Lock()
		for token, at := range registeredTokens {
			if at.DeviceID == id {
				delete(registeredTokens, token)
				break
			}
		}
		tokenMu.Unlock()

		return c.JSON(fiber.Map{
			"message": "Device deleted successfully",
		})
	})

	// Device heartbeat (legacy endpoint)
	devices.Post("/:id/heartbeat", func(c *fiber.Ctx) error {
		id := c.Params("id")

		result, err := db.Exec(
			"UPDATE devices SET last_seen = ?, status = ? WHERE id = ?",
			time.Now().Unix(), "online", id,
		)
		if err != nil {
			return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{
				"error": "Failed to update heartbeat",
			})
		}

		rowsAffected, _ := result.RowsAffected()
		if rowsAffected == 0 {
			return c.Status(fiber.StatusNotFound).JSON(fiber.Map{
				"error": "Device not found",
			})
		}

		row := db.QueryRow(
			`SELECT id, name, hostname, ip_address, mac_address, os_name, os_version, kernel_version, agent_version,
			 status, last_seen, created_at, public_key, user_data, system_uuid, serial_number, manufacturer, model,
			 cpu, memory, disk_size, timezone, agent_port, agent_ip FROM devices WHERE id = ?`,
			id,
		)
		d, err := scanDevice(row)
		if err != nil {
			return c.Status(fiber.StatusNotFound).JSON(fiber.Map{
				"error": "Device not found",
			})
		}

		return c.JSON(d)
	})

	// Send command to device
	devices.Post("/:id/command", func(c *fiber.Ctx) error {
		id := c.Params("id")

		var cmdReq struct {
			Type    string `json:"type"`
			Command string `json:"command"`
		}
		if err := c.BodyParser(&cmdReq); err != nil {
			return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{
				"error": "Invalid request body",
			})
		}

		if cmdReq.Type == "" || cmdReq.Command == "" {
			return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{
				"error": "type and command are required",
			})
		}

		// Validate command type
		if !allowedCommandTypes[cmdReq.Type] {
			return c.Status(fiber.StatusBadRequest).JSON(fiber.Map{
				"error": "invalid command type",
			})
		}

		// Get device
		row := db.QueryRow(
			`SELECT id, hostname, agent_ip, agent_port FROM devices WHERE id = ?`,
			id,
		)
		d, err := scanDevice(row)
		if err != nil {
			return c.Status(fiber.StatusNotFound).JSON(fiber.Map{
				"error": "Device not found",
			})
		}

		// Create command record with UUID
		cmdID := uuid.New().String()
		cmdData := CommandRequest{
			ID:        cmdID,
			Type:      cmdReq.Type,
			Payload:   map[string]interface{}{"command": cmdReq.Command},
			CreatedAt: time.Now(),
		}

		payloadJSON, _ := json.Marshal(cmdData)

		_, err = db.Exec(
			`INSERT INTO device_commands (id, device_id, type, payload, status, created_at) VALUES (?, ?, ?, ?, ?, ?)`,
			cmdID, id, cmdReq.Type, string(payloadJSON), "pending", time.Now().Unix(),
		)
		if err != nil {
			return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{
				"error": "Failed to create command",
			})
		}

		// Send command to agent asynchronously
		agentPort := 47991
		if d.AgentPort != nil {
			agentPort = *d.AgentPort
		}
		agentIP := ""
		if d.AgentIP != nil {
			agentIP = *d.AgentIP
		}

		// Look up the agent's API token
		tokenMu.RLock()
		var deviceToken string
		for t, at := range registeredTokens {
			if at.DeviceID == id {
				deviceToken = t
				break
			}
		}
		tokenMu.RUnlock()

		go func() {
			if sendErr := sendCommandToDevice(agentIP, agentPort, deviceToken, payloadJSON); sendErr != nil {
				log.Printf("Failed to send command %s to device %s: %v", cmdID, id, sendErr)
				_, err := db.Exec(
					`UPDATE device_commands SET status = ?, output = ?, finished_at = ? WHERE id = ?`,
					"failed", sendErr.Error(), time.Now().Unix(), cmdID,
				)
				if err != nil {
					log.Printf("Warning: could not update failed command status: %v", err)
				}
			} else {
				_, err := db.Exec(
					`UPDATE device_commands SET status = ?, finished_at = ? WHERE id = ?`,
					"completed", time.Now().Unix(), cmdID,
				)
				if err != nil {
					log.Printf("Warning: could not update command status: %v", err)
				}
			}
		}()

		return c.JSON(fiber.Map{
			"message":    "Command sent",
			"command_id": cmdID,
		})
	})

	// ============================================================
	// Sunshine/Remote Desktop endpoints
	// ============================================================

	// Get Sunshine status for a device
	devices.Get("/:id/sunshine", func(c *fiber.Ctx) error {
		id := c.Params("id")

		// Get device to verify it exists
		row := db.QueryRow(
			`SELECT id, hostname, ip_address, agent_ip, agent_port FROM devices WHERE id = ?`,
			id,
		)
		d, err := scanDevice(row)
		if err != nil {
			return c.Status(fiber.StatusNotFound).JSON(fiber.Map{
				"error": "Device not found",
			})
		}

		// Get Sunshine status from device_commands table
		var sunshinePayload string
		err = db.QueryRow(
			`SELECT payload FROM device_commands WHERE id = ?`,
			"sunshine_status_"+id,
		).Scan(&sunshinePayload)

		var sunshineInfo *sunshineStatus
		if err == nil && sunshinePayload != "" {
			var statusData map[string]interface{}
			if err := json.Unmarshal([]byte(sunshinePayload), &statusData); err == nil {
				installed, _ := statusData["installed"].(bool)
				running, _ := statusData["running"].(bool)
				portFloat, _ := statusData["port"].(float64)
				port := int(portFloat)
				if port == 0 {
					port = 47990
				}
				sunshineInfo = &sunshineStatus{
					Installed: installed,
					Running:   running,
					Port:      port,
				}
			}
		}

		// Get device IP for Moonlight connection
		deviceIP := d.IPAddress
		if d.AgentIP != nil && *d.AgentIP != "" {
			deviceIP = *d.AgentIP
		}

		return c.JSON(fiber.Map{
			"device_id":   id,
			"hostname":    d.Hostname,
			"device_ip":   deviceIP,
			"sunshine":    sunshineInfo,
			"moonlight_url": fmt.Sprintf("moonlight://%s", deviceIP),
			"web_url":     fmt.Sprintf("http://%s:47990", deviceIP),
		})
	})

	// Proxy to Sunshine web UI (for devices with Sunshine running)
	devices.Get("/:id/sunshine/proxy", func(c *fiber.Ctx) error {
		id := c.Params("id")

		// Get device
		row := db.QueryRow(
			`SELECT id, hostname, ip_address, agent_ip FROM devices WHERE id = ?`,
			id,
		)
		d, err := scanDevice(row)
		if err != nil {
			return c.Status(fiber.StatusNotFound).JSON(fiber.Map{
				"error": "Device not found",
			})
		}

		// Get Sunshine status to check if running
		var sunshinePayload string
		err = db.QueryRow(
			`SELECT payload FROM device_commands WHERE id = ?`,
			"sunshine_status_"+id,
		).Scan(&sunshinePayload)

		sunshinePort := 47990
		if err == nil && sunshinePayload != "" {
			var statusData map[string]interface{}
			if err := json.Unmarshal([]byte(sunshinePayload), &statusData); err == nil {
				running, _ := statusData["running"].(bool)
				if !running {
					return c.Status(fiber.StatusServiceUnavailable).JSON(fiber.Map{
						"error":   "Sunshine is not running on this device",
						"message": "Start Sunshine on the device before accessing remote desktop",
					})
				}
				if portFloat, ok := statusData["port"].(float64); ok && portFloat > 0 {
					sunshinePort = int(portFloat)
				}
			}
		}

		// Get target device IP
		deviceIP := d.IPAddress
		if d.AgentIP != nil && *d.AgentIP != "" {
			deviceIP = *d.AgentIP
		}

		// Redirect to Sunshine web UI (proxy would require WebSocket support)
		sunshineURL := fmt.Sprintf("http://%s:%d", deviceIP, sunshinePort)
		return c.Redirect(sunshineURL, fiber.StatusFound)
	})

	// Install Sunshine command (sends command to agent to install/configure Sunshine)
	devices.Post("/:id/sunshine/install", func(c *fiber.Ctx) error {
		id := c.Params("id")

		// Get device
		row := db.QueryRow(
			`SELECT id, hostname, agent_ip, agent_port FROM devices WHERE id = ?`,
			id,
		)
		d, err := scanDevice(row)
		if err != nil {
			return c.Status(fiber.StatusNotFound).JSON(fiber.Map{
				"error": "Device not found",
			})
		}

		// Create install command with UUID
		cmdID := uuid.New().String()
		cmdData := CommandRequest{
			ID:        cmdID,
			Type:      "shell",
			Payload:   map[string]interface{}{"command": "vaporrmm install-sunshine --port 47990"},
			CreatedAt: time.Now(),
		}

		payloadJSON, _ := json.Marshal(cmdData)

		_, err = db.Exec(
			`INSERT INTO device_commands (id, device_id, type, payload, status, created_at) VALUES (?, ?, ?, ?, ?, ?)`,
			cmdID, id, "sunshine_install", string(payloadJSON), "pending", time.Now().Unix(),
		)
		if err != nil {
			return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{
				"error": "Failed to create install command",
			})
		}

		// Send command to agent
		agentPort := 47991
		if d.AgentPort != nil {
			agentPort = *d.AgentPort
		}
		agentIP := ""
		if d.AgentIP != nil {
			agentIP = *d.AgentIP
		}

		// Look up the agent's API token
		tokenMu.RLock()
		var sunshineDeviceToken string
		for t, at := range registeredTokens {
			if at.DeviceID == id {
				sunshineDeviceToken = t
				break
			}
		}
		tokenMu.RUnlock()

		go func() {
			if sendErr := sendCommandToDevice(agentIP, agentPort, sunshineDeviceToken, payloadJSON); sendErr != nil {
				log.Printf("Failed to send Sunshine install command to device %s: %v", id, sendErr)
				_, err := db.Exec(
					`UPDATE device_commands SET status = ?, output = ?, finished_at = ? WHERE id = ?`,
					"failed", sendErr.Error(), time.Now().Unix(), cmdID,
				)
				if err != nil {
					log.Printf("Warning: could not update failed command status: %v", err)
				}
			} else {
				_, err := db.Exec(
					`UPDATE device_commands SET status = ?, finished_at = ? WHERE id = ?`,
					"completed", time.Now().Unix(), cmdID,
				)
				if err != nil {
					log.Printf("Warning: could not update command status: %v", err)
				}
			}
		}()

		return c.JSON(fiber.Map{
			"message":    "Sunshine install command sent",
			"command_id": cmdID,
		})
	})

	// ============================================================
	// Tailscale endpoints
	// ============================================================

	// Get Tailscale status for a device
	devices.Get("/:id/tailscale", func(c *fiber.Ctx) error {
		id := c.Params("id")

		// Get device to verify it exists
		row := db.QueryRow(
			`SELECT id, hostname, ip_address, agent_ip, agent_port FROM devices WHERE id = ?`,
			id,
		)
		d, err := scanDevice(row)
		if err != nil {
			return c.Status(fiber.StatusNotFound).JSON(fiber.Map{
				"error": "Device not found",
			})
		}

		// Get Tailscale status from device_commands table
		var tailscalePayload string
		err = db.QueryRow(
			`SELECT payload FROM device_commands WHERE id = ?`,
			"tailscale_status_"+id,
		).Scan(&tailscalePayload)

		var tailscaleInfo *tailscaleStatus
		if err == nil && tailscalePayload != "" {
			var statusData map[string]interface{}
			if err := json.Unmarshal([]byte(tailscalePayload), &statusData); err == nil {
				installed, _ := statusData["installed"].(bool)
				connected, _ := statusData["connected"].(bool)
				ip, _ := statusData["ip"].(string)
				hostname, _ := statusData["hostname"].(string)
				peersFloat, _ := statusData["peers"].(float64)
				backendState, _ := statusData["backend_state"].(string)
				peers := int(peersFloat)
				tailscaleInfo = &tailscaleStatus{
					Installed:    installed,
					Connected:    connected,
					IP:           ip,
					Hostname:     hostname,
					Peers:        peers,
					BackendState: backendState,
				}
			}
		}

		// Get device IP (prefer Tailscale IP if available)
		deviceIP := d.IPAddress
		if tailscaleInfo != nil && tailscaleInfo.IP != "" {
			deviceIP = tailscaleInfo.IP
		} else if d.AgentIP != nil && *d.AgentIP != "" {
			deviceIP = *d.AgentIP
		}

		return c.JSON(fiber.Map{
			"device_id": id,
			"hostname":  d.Hostname,
			"device_ip": deviceIP,
			"tailscale": tailscaleInfo,
		})
	})

	// Install Tailscale command (sends command to agent to install Tailscale)
	devices.Post("/:id/tailscale/install", func(c *fiber.Ctx) error {
		id := c.Params("id")

		// Parse request body for optional authkey
		var req struct {
			AuthKey  string `json:"auth_key,omitempty"`
			ExitNode bool   `json:"exit_node,omitempty"`
		}
		if err := c.BodyParser(&req); err != nil {
			// Continue with empty req on parse error
		}

		// Get device
		row := db.QueryRow(
			`SELECT id, hostname, agent_ip, agent_port FROM devices WHERE id = ?`,
			id,
		)
		d, err := scanDevice(row)
		if err != nil {
			return c.Status(fiber.StatusNotFound).JSON(fiber.Map{
				"error": "Device not found",
			})
		}

		// Build install command
		installCmd := "vaporrmm install-tailscale"
		if req.AuthKey != "" {
			installCmd += fmt.Sprintf(" --authkey=%s", req.AuthKey)
		}
		if req.ExitNode {
			installCmd += " --exit-node"
		}

		// Create install command with UUID
		cmdID := uuid.New().String()
		cmdData := CommandRequest{
			ID:        cmdID,
			Type:      "shell",
			Payload:   map[string]interface{}{"command": installCmd},
			CreatedAt: time.Now(),
		}

		payloadJSON, _ := json.Marshal(cmdData)

		_, err = db.Exec(
			`INSERT INTO device_commands (id, device_id, type, payload, status, created_at) VALUES (?, ?, ?, ?, ?, ?)`,
			cmdID, id, "tailscale_install", string(payloadJSON), "pending", time.Now().Unix(),
		)
		if err != nil {
			return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{
				"error": "Failed to create install command",
			})
		}

		// Send command to agent
		agentPort := 47991
		if d.AgentPort != nil {
			agentPort = *d.AgentPort
		}
		agentIP := ""
		if d.AgentIP != nil {
			agentIP = *d.AgentIP
		}

		// Look up the agent's API token
		tokenMu.RLock()
		var tailscaleDeviceToken string
		for t, at := range registeredTokens {
			if at.DeviceID == id {
				tailscaleDeviceToken = t
				break
			}
		}
		tokenMu.RUnlock()

		go func() {
			if sendErr := sendCommandToDevice(agentIP, agentPort, tailscaleDeviceToken, payloadJSON); sendErr != nil {
				log.Printf("Failed to send Tailscale install command to device %s: %v", id, sendErr)
				_, err := db.Exec(
					`UPDATE device_commands SET status = ?, output = ?, finished_at = ? WHERE id = ?`,
					"failed", sendErr.Error(), time.Now().Unix(), cmdID,
				)
				if err != nil {
					log.Printf("Warning: could not update failed command status: %v", err)
				}
			} else {
				_, err := db.Exec(
					`UPDATE device_commands SET status = ?, finished_at = ? WHERE id = ?`,
					"completed", time.Now().Unix(), cmdID,
				)
				if err != nil {
					log.Printf("Warning: could not update command status: %v", err)
				}
			}
		}()

		return c.JSON(fiber.Map{
			"message":    "Tailscale install command sent",
			"command_id": cmdID,
		})
	})

	// Generate Tailscale auth key (requires Tailscale CLI on server)
	devices.Post("/:id/tailscale/auth-key", func(c *fiber.Ctx) error {
		id := c.Params("id")

		// Get device
		_, err := scanDevice(db.QueryRow(
			`SELECT id, hostname FROM devices WHERE id = ?`,
			id,
		))
		if err != nil {
			return c.Status(fiber.StatusNotFound).JSON(fiber.Map{
				"error": "Device not found",
			})
		}

		// Parse request for auth key options
		var req struct {
			Reusable  bool     `json:"reusable,omitempty"`
			Ephemeral bool     `json:"ephemeral,omitempty"`
			Tags      []string `json:"tags,omitempty"`
		}
		if err := c.BodyParser(&req); err != nil {
			// Continue with empty req on parse error
		}

		// Build tailscale command
		args := []string{"tailscale", "auth-key", "create"}
		if req.Reusable {
			args = append(args, "--reusable")
		}
		if req.Ephemeral {
			args = append(args, "--ephemeral")
		}
		for _, tag := range req.Tags {
			args = append(args, "--tag="+tag)
		}

		cmd := exec.Command(args[0], args[1:]...)
		output, err := cmd.Output()
		if err != nil {
			return c.Status(fiber.StatusInternalServerError).JSON(fiber.Map{
				"error":   "Failed to generate auth key",
				"message": "Ensure Tailscale CLI is installed and authenticated on the server",
			})
		}

		authKey := strings.TrimSpace(string(output))

		return c.JSON(fiber.Map{
			"auth_key": authKey,
			"message":  "Auth key generated successfully",
		})
	})

	log.Printf("Starting Vapor RMM Server on port %d", serverPort)
	if err := app.Listen(fmt.Sprintf(":%d", serverPort)); err != nil {
		log.Fatalf("Failed to start server: %v", err)
	}
}

// createDefaultAdmin creates a default admin user if none exists
func createDefaultAdmin() {
	var count int
	if err := db.QueryRow("SELECT COUNT(*) FROM users").Scan(&count); err != nil {
		log.Printf("Warning: could not check users table: %v", err)
		return
	}

	if count == 0 {
		defaultPassword := "admin123" // Change in production!
		
		// Hash password with bcrypt
		hashedPassword, err := bcrypt.GenerateFromPassword([]byte(defaultPassword), bcrypt.DefaultCost)
		if err != nil {
			log.Printf("Warning: could not hash password: %v", err)
			return
		}
		
		userID := uuid.New().String()
		_, err = db.Exec(
			`INSERT INTO users (id, email, password_hash, name, role, created_at) VALUES (?, ?, ?, ?, ?, ?)`,
			userID, "admin@vaporrmm.local", string(hashedPassword), "Admin", "admin", time.Now().Unix(),
		)
		if err != nil {
			log.Printf("Warning: could not create default admin user: %v", err)
		} else {
			log.Println("Created default admin user (email: admin@vaporrmm.local - change default password!)")
		}
	}
}