# vaporRMM Server & Testing Configuration
# Copy this file to .env then run docker/setup-docker.sh, which fills
# in the __GENERATE_ME__ sentinel values below with cryptographically
# random secrets and prints the admin password ONCE. Do not hand-edit
# this file with placeholder credentials and run the server directly —
# the boot path refuses to start when any required field is still set
# to the sentinel value, on purpose.

# ============================================
# REQUIRED — sentinel values, must be filled by setup-docker.sh
# ============================================

# JWT signing key. 32+ bytes of entropy required. Generated by
# setup-docker.sh via `openssl rand -base64 48`.
JWT_SECRET=__GENERATE_ME__

# Encryption key for at-rest secrets (SMTP, webhook secrets, OIDC
# client secrets, AI provider keys). Generated by setup-docker.sh
# via `openssl rand -base64 32`.
SECRETS_ENCRYPTION_KEY=__GENERATE_ME__

# Initial admin password for admin@vaporrmm.local. Generated by
# setup-docker.sh and printed to stdout exactly once. Record it
# before the setup script exits; the server hashes it and the
# plaintext is unrecoverable afterwards.
ADMIN_PASSWORD=__GENERATE_ME__

# ============================================
# OPTIONAL: Tailscale Integration
# ============================================

# Get an auth key from https://login.tailscale.com/admin/settings/keys
# Set this to enable Tailscale features in the dashboard
# TAILSCALE_AUTH_KEY=tskey-auth-k1234567cnTRL-abcdefghijklmnopqrstuvwxyz

# ============================================
# OPTIONAL: Advanced Server Settings
# ============================================

# Database (SQLite default)
# DATABASE_PATH=/app/data/vapor_rmm.db

# For PostgreSQL, uncomment in docker-compose.full.yml and use:
# DATABASE_URL=postgres://vaporrmm:vaporrmm@postgres:5432/vaporrmm?sslmode=disable

# Server binding. Default compose files bind to 127.0.0.1:8080
# (host loopback only). Set EXPOSE_PUBLICLY=1 in the host
# environment when starting docker compose to bind on 0.0.0.0
# instead — production deployments should do this only behind
# Caddy / a reverse proxy. Codex #3 explicitly named "do not bind
# ports to 0.0.0.0 by default; bind to 127.0.0.1 and document
# how to expose externally".

# CORS origins (add your Tailscale MagicDNS domain if using Tailscale)
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://vaporrmm-server.your-tailnet.ts.net

# Agent settings
# DEFAULT_OFFLINE_THRESHOLD=300
# AGENT_REGISTRATION_SECRET=

# ============================================
# OPTIONAL: Moonlight Web Stream
# ============================================

# Set to the LAN IP of the Docker host for WebRTC NAT traversal
# WEBRTC_NAT_1TO1_HOST=192.168.1.100

# URL where the dashboard can reach moonlight-web-stream
# MOONLIGHT_WEB_URL=http://localhost:8081

# ============================================
# TLS (optional)
# ============================================
# TLS_CERT=/app/certs/server.crt
# TLS_KEY=/app/certs/server.key
# AGENT_CA_CERT=/app/certs/ca.crt

# ============================================
# Redis (optional)
# ============================================
# REDIS_ADDR=redis:6379
# REDIS_PASSWORD=
# REDIS_DB=0
