# vaporRMM Server Configuration
# Copy to /etc/vaporrmm/server.env and customize

# Required: Strong random secret for JWT signing
# Generate with: openssl rand -base64 32
JWT_SECRET=change-me-to-a-random-string

# Database (SQLite default, PostgreSQL optional)
DATABASE_PATH=/opt/vaporrmm/data/vapor_rmm.db
# For PostgreSQL, comment out DATABASE_PATH and use:
# DATABASE_URL=postgres://vaporrmm:password@localhost:5432/vaporrmm?sslmode=disable

# Admin credentials (only used on first boot to create admin user)
ADMIN_PASSWORD=ChangeMeStrongPassword123!

# Server binding
SERVER_PORT=8080
# Bind to all interfaces so remote agents can connect
# SERVER_HOST=0.0.0.0

# CORS — add your dashboard domain
CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# Agent settings
DEFAULT_OFFLINE_THRESHOLD=300
AGENT_WS_PORT=8081
AGENT_REGISTRATION_SECRET=

# TLS (optional but recommended for production)
# TLS_CERT=/opt/vaporrmm/certs/server.crt
# TLS_KEY=/opt/vaporrmm/certs/server.key
# AGENT_CA_CERT=/opt/vaporrmm/certs/ca.crt

# Redis (optional — enables distributed rate limiting & WS pub/sub)
# REDIS_ADDR=localhost:6379
# REDIS_PASSWORD=
# REDIS_DB=0

# Email (optional — for password reset)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=app-password
# SMTP_FROM=noreply@your-domain.com
# SMTP_TLS=true
