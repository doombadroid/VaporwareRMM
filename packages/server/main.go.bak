	// Generate agent install link/script
	branding.Get("/agent-install", func(c *fiber.Ctx) error {
		// Get branding
		var brandingConfig BrandingConfig
		db.QueryRow(
			`SELECT app_name, icon_url, company_name, primary_color FROM branding WHERE id = 'default'`,
		).Scan(&brandingConfig.AppName, &brandingConfig.IconURL, &brandingConfig.CompanyName, &brandingConfig.PrimaryColor)

		// Get server URL from request
		serverURL := fmt.Sprintf("%s://%s", c.Protocol(), c.Hostname())

		// Generate install script with branding
		installScript := fmt.Sprintf(`#!/bin/bash
# %s Agent Installation Script
# Generated by %s
# Server: %s

set -euo pipefail

APP_NAME="%s"
SERVER_URL="%s"
ICON_URL="%s"

echo "Installing $APP_NAME agent..."
echo "Connecting to server: $SERVER_URL"

# Download and install agent
curl -fsSL "$SERVER_URL/api/agent/install.sh" | bash -s -- --server "$SERVER_URL"

# Configure branding
if [ -n "$ICON_URL" ]; then
    echo "Configuring agent branding..."
    mkdir -p /etc/vaporrmm
    echo "$ICON_URL" > /etc/vaporrmm/agent_icon_url
fi

echo "$APP_NAME agent installation complete!"
`, brandingConfig.CompanyName, brandingConfig.CompanyName, serverURL, brandingConfig.AppName, serverURL, brandingConfig.IconURL)

		format := c.Query("format", "script")
		if format == "json" {
			return c.JSON(fiber.Map{
				"app_name":      brandingConfig.AppName,
				"company_name":  brandingConfig.CompanyName,
				"icon_url":      brandingConfig.IconURL,
				"server_url":    serverURL,
				"install_url":   fmt.Sprintf("%s/api/agent/install.sh", serverURL),
				"install_command": fmt.Sprintf("curl -fsSL %s/api/agent/install.sh | bash", serverURL),
			})
		}

		c.Set("Content-Type", "text/x-shellscript")
		c.Set("Content-Disposition", fmt.Sprintf("attachment; filename=%s-agent-install.sh", brandingConfig.AppName))
		return c.SendString(installScript)
	})

	// Get per-client/site install links
	branding.Get("/install-links", func(c *fiber.Ctx) error {
		// Get branding
		var brandingConfig BrandingConfig
		db.QueryRow(
			`SELECT app_name, icon_url, company_name, primary_color FROM branding WHERE id = 'default'`,
		).Scan(&brandingConfig.AppName, &brandingConfig.IconURL, &brandingConfig.CompanyName, &brandingConfig.PrimaryColor)

		serverURL := fmt.Sprintf("%s://%s", c.Protocol(), c.Hostname())

