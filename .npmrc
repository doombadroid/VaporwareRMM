# Next.js + recharts + React 19 don't tolerate pnpm's symlink-style
# node_modules well — recharts tries to resolve sibling sub-deps that aren't
# hoisted, and React ends up duplicated across nested module trees, causing
# "Cannot read properties of null (reading 'useReducer')" in dev mode and
# "Module not found '../component/Dots'" at build. Forcing a hoisted layout
# matches what npm/yarn produce and the CI environment expects.
node-linker=hoisted
