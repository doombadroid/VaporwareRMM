# ─────────────────────────────────────────────────────────────
# vaporRMM — environment variables
#
# Copy to .env and fill in values before running docker compose:
#   cp .env.example .env
#
# REQUIRED fields will cause docker compose to refuse to start if empty.
# ─────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────
# REQUIRED. Strong random password for PostgreSQL.
# Generate: openssl rand -base64 24
POSTGRES_PASSWORD=change-me-strong-db-password

# ── Server ────────────────────────────────────────────────────
# REQUIRED. Secret for signing JWT tokens. Min 32 chars, random.
# Generate: openssl rand -base64 32
JWT_SECRET=change-me-generate-with-openssl-rand-base64-32

# REQUIRED for production. 32-byte key (base64) used to encrypt SMTP/webhook
# secrets at rest in the DB. Rotating this invalidates previously stored secrets.
# Generate: openssl rand -base64 32
SECRETS_ENCRYPTION_KEY=change-me-generate-with-openssl-rand-base64-32

# Optional. If set, server creates the admin user with this password.
# If unset, a random password is generated and printed to stdout ONCE on first run.
# Capture with: docker compose logs server | grep Password
# ADMIN_PASSWORD=

# Optional. Restrict CORS to your dashboard domain.
# Defaults to * (any origin) if empty — fine for localhost, restrict for production.
# CORS_ORIGINS=https://rmm.example.com

# Optional. Comma-separated list of subnets allowed to be agent-side.
# Used by /caddy/ask gate for on-demand TLS subdomain validation.
# BASE_DOMAIN must match the wildcard zone in Caddyfile (e.g. rmm.example.com).
# BASE_DOMAIN=rmm.example.com

# Optional. Hours of grace after suspension before a tenant is hard-blocked.
# Default 72.
# SUSPENSION_GRACE_HOURS=72

# Optional. Open self-serve signup (default off).
#   SIGNUP_OPEN=1                    → anyone can sign up
#   SIGNUP_INVITE_CODE=<shared code> → only with the matching code
# SIGNUP_OPEN=
# SIGNUP_INVITE_CODE=

# Optional. Bypass rate limits in CI / local dev only. NEVER enable in prod.
# DISABLE_RATE_LIMIT=

# Optional. Pin the Sunshine release the install scripts download.
# Validated against ^v?\d+\.\d+\.\d+$ at boot.
# SUNSHINE_VERSION=v2025.118.151840

# Optional. Default registration secret used to bootstrap the default tenant.
# REGISTRATION_SECRET=change-me-or-leave-empty

# Optional. Redis URL for multi-node WebSocket fan-out + rate-limit sharing.
# REDIS_URL=redis://redis:6379/0

# ── TLS / Caddy ───────────────────────────────────────────────
# Domain Caddy listens on.
#   localhost           → Caddy local CA (self-signed, no internet needed)
#   rmm.example.com     → Caddy auto-provisions Let's Encrypt (ports 80+443 must be public)
DOMAIN=localhost

# Email for Let's Encrypt registration (required for real domains).
# ACME_EMAIL=ops@example.com

# ── Dev profile: example agent ────────────────────────────────
# Only needed if running: docker compose --profile dev up
# Must be a random token the agent sends to authenticate with the server.
# Generate: openssl rand -base64 32
# AGENT_TOKEN=change-me-random-agent-token
